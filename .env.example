# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Frontend URL (used to whitelist CORS origin) ──────────────────────────────
# Set this to your Render service URL (no trailing slash)
FRONTEND_URL=https://civic-service-resolution.onrender.com

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change_this_to_a_random_64_char_string_in_production
JWT_REFRESH_SECRET=change_this_to_another_random_64_char_string_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=10

# ── CORS (optional — extra origins beyond the hardcoded defaults) ─────────────
# Comma-separated. Leave blank unless you have additional frontend domains.
CORS_ORIGINS=

# ── Redis (optional — analytics cache disabled if unset) ─────────────────────
REDIS_URL=

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Cloudflare (optional) ─────────────────────────────────────────────────────
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=
