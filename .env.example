# Server
NODE_ENV=development
PORT=3000

# JWT
JWT_ACCESS_SECRET=change_this_to_a_random_64_char_string_in_production
JWT_REFRESH_SECRET=change_this_to_another_random_64_char_string_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=10
ANALYTICS_RATE_LIMIT_MAX=30

# Redis (optional — analytics cache disabled if unset)
REDIS_URL=redis://localhost:6379

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5173

# Logging
LOG_LEVEL=info

# Database (PostgreSQL — for production migration)
DATABASE_URL=postgresql://user:password@localhost:5432/civic_issues

# Cloudflare (optional) — set these if you deploy or use Cloudflare APIs
# Create an API Token on Cloudflare with appropriate scopes (e.g., Zones:Read, Workers:Edit, Account:Read)
# Then set the values below in a local `.env` (do NOT commit secrets to git)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=
